{
    "label" : "logout",
    "action" : "hyprctl dispatch exit 0",
    "text" : "Logout      "
    "keybind" : "l"
}

{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Poweroff"
    "keybind" : "p"
}

{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Sleep"
    "keybind" : "s"
}

{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot"
    "keybind" : "r"
}
